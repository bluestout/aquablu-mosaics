{% if product.metafields.custom.icon_code_1 %}
  <style>
    .recommended-applications {
      padding: 20px 40px;
      margin-top: 50px;
    }

    .recommended-applications__inner {
      max-width: 660px;
      margin: 0 auto;
    }

    .recommended-applications__title {
      color: #000;
      text-align: center;
      font-size: 20px;
      font-style: normal;
      font-weight: 500;
      line-height: 28px;
      letter-spacing: 0.9px;
      text-transform: uppercase;
    }

    .recommended-applications .vl {
      height: 69px;
    }

    .recommended-applications .product-block--icon-area {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .recommended-applications .icon-item-on {
      position: relative;
      top: -20px;
    }

    .recommended-applications .icon-item svg {
      height: unset;
      width: unset;
    }

    @media (max-width: 768px) {
      .recommended-applications {
        padding: 16px 20px;
        margin-top: 0px;
      }

      .recommended-applications__title {
        font-size: 15px;
      }

      .recommended-applications .icon-item svg {
        height: 40px;
        width: 65px;
      }

      .recommended-applications .vl {
        height: 49px;
      }

      .recommended-applications .icon-item-on {
        position: relative;
        top: -15px;
      }

      .recommended-applications.index-section{
        margin-top: 0px;
      }
    }
  </style>

