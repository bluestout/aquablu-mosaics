{% style %}
    .section-{{ section.id }} {
        background-color: white;
    }

    .section-{{ section.id }} .page-width {
        padding-top: 36px;
    }

    .section-{{ section.id }} h2 {
        color: #374759;
        font-family: "Jost";
        font-size: calc(var(--font-heading-scale, 1) * 27px);
        font-weight: 300;
        letter-spacing: 1.4px;
        text-align: center;
        margin: 0 20px 30px;
    }

    .section-{{ section.id }} .blocks-group {
        display: flex;
        flex-wrap: wrap;
        margin-bottom: 2rem;
        padding: 0;
        list-style: none;
        column-gap: var(--grid-mobile-spacing);
        row-gap: var(--grid-mobile-spacing);
        width: 100%;
    }

    .section-{{ section.id }} .lookfy-block {
        width: calc(50% - var(--grid-mobile-spacing) / 2);
        max-width: calc(50% - var(--grid-mobile-spacing) / 2);
    }

    .section-{{ section.id }} .lookfy-block a img {
        transition-duration: 600ms;
        transition-timing-function: ease-in-out;
        transform: scale(1, 1) rotate(0deg);
    }

    .section-{{ section.id }} .lookfy-block a:hover img {
        transform: scale(1.1, 1.1) rotate(0deg);
    }

    .section-{{ section.id }} .lookfy-block div {
        padding-top: 28px;
        padding-bottom: 10px;
        color: #374759;
        font-size: 16px;
        line-height: 26px;
        font-family: Poppins;
        text-align: center;
    }

    @media (min-width: 768px) {
        .section-{{ section.id }} .blocks-grid {
            column-gap: var(--grid-desktop-spacing);
            row-gap: var(--grid-desktop-spacing);
        }

        .section-{{ section.id }} .lookfy-block {
            width: calc(25% - var(--grid-desktop-spacing) * 3 / 4);
            max-width: calc(25% - var(--grid-desktop-spacing) * 3 / 4);
        }
    }

    @media (min-width: 1024px) {
        .section-{{ section.id }} .lookfy-block {
            width: calc(25% - var(--grid-desktop-spacing) * 3 / 4);
            max-width: calc(25% - var(--grid-desktop-spacing) * 3 / 4);
        }
    }

    @media screen and (max-width: 750px) {
        .section-{{ section.id }} .page-width {
            margin-bottom: -20px;
        }
    }
{% endstyle %}

<div class="section-{{ section.id }}">
    <link href="https://fonts.googleapis.com/css2?family=Poppins&amp;display=swap" rel="stylesheet">
    <div class="page-width">
        <h2>{{ section.settings.header }}</h2>
        <div class="blocks-group">
            {% for block in section.blocks %}
                <div class="lookfy-block">
                    <a href="{{ block.settings.link }}">
                        <img src="{{ block.settings.image | img_url: 'master' }}" width="100%" height="100%" alt="lookfy-img-{{ forloop.index }}">
                    </a>
                    <div>{{ block.settings.title }}</div>
                </div>
            {% endfor %}
        </div>
    </div>
</div>

{% schema %}
{
    "name": "Lookfy Section 1",
    "settings": [
        {
            "type": "text",
            "id": "header",
            "label": "Header"
        }
    ],
    "blocks": [
        {
            "type": "block",
            "name": "block",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "Image"
                },
                {
                    "type": "text",
                    "id": "title",
                    "label": "Title"
                },
                {
                    "type": "url",
                    "id": "link",
                    "label": "Link"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Lookfy Section 1"
        }
    ]
}
{% endschema %}