{%- if section.settings.image != blank or section.settings.heading != blank -%}
  <style>
    /* ===== Product Feature: Image with Text ===== */
    .pfiwt {
      padding-top: 60px;
      padding-bottom: 60px;
      background-color: #fff;
    }

    .pfiwt__inner {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 40px;
    }

    .pfiwt__inner--image-right {
      flex-direction: row-reverse;
    }

    .pfiwt__image-col {
      flex: 0 0 auto;
      width: 50%;
    }

    .pfiwt__image-wrapper {
      position: relative;
      width: 100%;
      overflow: hidden;
    }

    .pfiwt__image-wrapper img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .pfiwt__text-col {
      flex: 1 1 0;
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .pfiwt__heading {
      font-size: 20px;
      font-weight: 700;
      line-height: 28px;
      letter-spacing: 0.9px;
      text-transform: uppercase;
      color: #000;
      margin: 0;
    }

    .pfiwt__body {
      font-size: 16px;
      font-weight: 300;
      line-height: 24px;
      color: #000;
    }

    .pfiwt__body p {
      margin: 0 0 16px;
    }

    .pfiwt__body p:last-child {
      margin-bottom: 0;
    }

    .pfiwt__body a {
      color: #000;
      text-decoration: underline;
      text-decoration-skip-ink: none;
    }

    .pfiwt__body a:hover {
      opacity: 0.75;
    }

    .pfiwt__body em,
    .pfiwt__body i {
      font-style: italic;
    }

    @media (max-width: 768px) {
      .pfiwt {
        padding-top: 40px;
        padding-bottom: 40px;
      }

      .pfiwt__inner,
      .pfiwt__inner--image-right {
        flex-direction: column;
        gap: 24px;
      }

      .pfiwt__image-col {
        width: 100%;
      }

      .pfiwt__text-col {
        gap: 16px;
      }
    }

    @media (max-width: 1024px) {
      .pfiwt__inner {
        align-items: flex-start;
      }
    }
  </style>

  <div class="pfiwt" id="ProductFeatImageWithText-{{ section.id }}">
    <div class="page-width">
      <div class="pfiwt__inner{% if section.settings.image_position == 'right' %} pfiwt__inner--image-right{% endif %}">
        {%- if section.settings.image != blank -%}
          <div class="pfiwt__image-col">
            <div class="pfiwt__image-wrapper">
              {{
                section.settings.image
                | image_url: width: 1260
                | image_tag: loading: 'lazy', alt: section.settings.image.alt
                | default: section.settings.heading, widths: '400, 600, 800, 1000, 1260'
              }}
            </div>
          </div>
        {%- elsif section.settings.image == blank -%}
          <div class="pfiwt__image-col">
            <div class="pfiwt__image-wrapper">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          </div>
        {%- endif -%}

        <div class="pfiwt__text-col">
          {%- if section.settings.heading != blank -%}
            <h2 class="pfiwt__heading">{{ section.settings.heading | escape }}</h2>
          {%- endif -%}

          {%- if section.settings.body_text != blank -%}
            <div class="pfiwt__body">
              {{ section.settings.body_text }}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Image with Text",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PORCELAIN DECO TILE FOR POOLS"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Add your product description here. You can include <a href=\"#\">inline links</a> and use italic text for disclaimers.</p>"
    }
  ],
  "presets": [
    {
      "name": "Image with Text"
    }
  ]
}
{% endschema %}
