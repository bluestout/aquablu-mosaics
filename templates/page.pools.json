    "faq_bHLcq3": {
      "type": "faq",
      "blocks": {
        "question_WgWEgm": {
          "type": "question",
          "settings": {
            "title": "What types of pool products does AquaBlu offer?",
            "text": "<p>AquaBlu Mosaics provides a full suite of luxury pool products, including tiles, mosaics, outdoor furniture, poolside daybeds, water features, and decorative accents - everything you need to create a resort-style backyard.</p>"
          }
        },
        "question_ibptLL": {
          "type": "question",
          "settings": {
            "title": "Are pool tiles suitable for indoor and outdoor use?",
            "text": "<p>Yes! Our pool tiles are designed for both indoor and outdoor environments, including pools, patios, and spa areas. They are weather-resistant, UV-protected, and built to last.</p>"
          }
        },
        "question_KeqLhc": {
          "type": "question",
          "settings": {
            "title": "Are these pool products eco-friendly?",
            "text": "<p>Many of our pool products are made with sustainable materials, and a portion of sales supports ocean conservation initiatives, helping you make responsible design choices.</p>"
          }
        },
        "question_tarnCU": {
          "type": "question",
          "settings": {
            "title": "Do you offer custom pool products or designs?",
            "text": "<p>Yes! From custom mosaics to tailored outdoor furniture arrangements, AquaBlu works with you to bring one-of-a-kind pool visions to life. Let us help you bring your vision to life. </p>"
          }
        },
        "question_h9pUCd": {
          "type": "question",
          "settings": {
            "title": "What type of pool tile do you offer?",
            "text": "<p>AquaBlu Mosaics offers a curated selection of luxury pool tiles designed for beauty, durability, and lasting performance. Our collection includes glass tile, porcelain tiles, and decorative accent tiles, each engineered to resist fading, cracking, and pool chemicals. Whether you’re designing a sleek modern pool, a spa, or a resort-style backyard, our tiles combine timeless style with long-term functionality.</p>"
          }
        },
        "question_tEUX3p": {
          "type": "question",
          "settings": {
            "title": "Will these pool products withstand harsh climates?",
            "text": "<p>Yes. All our tiles, mosaics, furniture, and outdoor accessories are designed for durability in sun, rain, and pool chemicals, making them perfect for any climate.</p>"
          }
        },
        "question_r6DRxb": {
          "type": "question",
          "settings": {
            "title": "Why choose AquaBlu for my pool and outdoor space?",
            "text": "<p>AquaBlu combines luxury design, premium quality, and long-lasting performance across a full range of pool products. From stunning mosaics to stylish poolside furniture, we help you create an elegant, functional, and resort-style backyard.</p>"
          }
        }
      },
